# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=False

# Roboflow API Configuration
# Get your API key from: https://roboflow.com
# 1. Sign up at https://app.roboflow.com
# 2. Create or select your project
# 3. Go to Settings > Roboflow API to get your API key
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_API_KEY=your_roboflow_api_key_here
MODEL_ID=your_model_id_here

# Database (Heroku will auto-set DATABASE_URL)
# DATABASE_URL will be automatically provided by Heroku PostgreSQL addon

# Security Settings
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=/tmp/uploads
